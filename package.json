{
  "name": "webapp-stack-g1",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "WebApp Stack G One Point Zero — TS + React + Vite + Tailwind + Firebase starter template.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noCheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "emulators": "npx --yes firebase-tools emulators:start",
    "emulators:export": "npx --yes firebase-tools emulators:start --export-on-exit=.emulator-data --import=.emulator-data",
    "deploy": "bash .SYSTEMX/scripts/deploy.sh",
    "system:audit": "bash .SYSTEMX/scripts/system-audit.sh",
    "sync:system": "bash .SYSTEMX/wsg-agi.sh",
    "sync:system:check": "bash .SYSTEMX/wsg-agi.sh --check",
    "setup:unified:scrape:list": "node .SYSTEMX/Unified-Setup-Process/scrape/repo-manifest-scraper.mjs --list",
    "setup:unified:scrape:dry-run": "node .SYSTEMX/Unified-Setup-Process/scrape/repo-manifest-scraper.mjs --dry-run",
    "setup:unified:scrape": "node .SYSTEMX/Unified-Setup-Process/scrape/repo-manifest-scraper.mjs --write",
    "setup:packet:export": "bash .SYSTEMX/scripts/build-setup-packet.sh",
    "setup:packet:import": "bash .SYSTEMX/scripts/import-setup-packet.sh",
    "setup:test-users": "node scripts/setup/seed-test-users.mjs",
    "setup:test-users:write": "node scripts/setup/seed-test-users.mjs --write",
    "account-levels:check": "node .SYSTEMX/scripts/account-level-check.mjs",
    "auth:mfa:check": "node .SYSTEMX/scripts/auth-mfa-readiness-check.mjs",
    "ci:lint": "eslint . --max-warnings=0",
    "ci:typecheck": "tsc --noEmit -p tsconfig.json",
    "ci:test": "npm run test --if-present",
    "ci:build": "vite build",
    "ci:audit": "npm audit --audit-level=high",
    "ci:security": "node .SYSTEMX/scripts/security-check.mjs && node .SYSTEMX/scripts/account-level-check.mjs && node .SYSTEMX/scripts/auth-mfa-readiness-check.mjs"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "lucide-react": "^0.484.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^17.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.1.3"
  }
}
