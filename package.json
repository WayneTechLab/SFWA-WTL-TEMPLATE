{
  "name": "sfwa-wtl-g1",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "SFWA-WTL-G1 — Standard Firebase Web App, Wayne Tech Lab Generation 1.",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "node .SYSTEMX/LAN/runner.mjs vite",
    "dev:public": "vite",
    "lan": "node .SYSTEMX/LAN/runner.mjs lan",
    "build": "tsc -b --noCheck && vite build && node .SYSTEMX/scripts/assert-lan-isolation.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test .SYSTEMX/tests/*.test.mjs",
    "emulators": "npm run build && node .SYSTEMX/LAN/runner.mjs firebase",
    "emulators:public": "npx --no-install firebase emulators:start",
    "emulators:export": "npx --no-install firebase emulators:start --export-on-exit=.emulator-data --import=.emulator-data",
    "deploy": "node .SYSTEMX/cli/systemx.mjs deploy",
    "system:audit": "node .SYSTEMX/cli/systemx.mjs audit",
    "sync:system": "node .SYSTEMX/cli/systemx.mjs sync",
    "sync:system:check": "node .SYSTEMX/cli/systemx.mjs sync --check",
    "wtl:sync": "node .SYSTEMX/cli/systemx.mjs sync",
    "wtl:agi": "node .SYSTEMX/cli/systemx.mjs sync",
    "wtl:setup": "node .SYSTEMX/cli/systemx.mjs setup",
    "wtl:menu": "node .SYSTEMX/cli/systemx.mjs menu",
    "wtl:doctor": "node .SYSTEMX/cli/systemx.mjs doctor",
    "wtl:platform": "node .SYSTEMX/cli/systemx.mjs platform",
    "wtl:local": "node .SYSTEMX/cli/systemx.mjs local",
    "wtl:start-day": "node .SYSTEMX/cli/systemx.mjs local start-day",
    "wtl:end-day": "node .SYSTEMX/cli/systemx.mjs local end-day",
    "wtl:bus": "node .SYSTEMX/cli/systemx.mjs bus",
    "wtl:mcp": "node .SYSTEMX/cli/systemx.mjs mcp generate",
    "diagnostics": "node .SYSTEMX/cli/systemx.mjs diagnostics",
    "setup:unified:scrape:list": "node .SYSTEMX/Unified-Setup-Process/scrape/repo-manifest-scraper.mjs --list",
    "setup:unified:scrape:dry-run": "node .SYSTEMX/Unified-Setup-Process/scrape/repo-manifest-scraper.mjs --dry-run",
    "setup:unified:scrape": "node .SYSTEMX/Unified-Setup-Process/scrape/repo-manifest-scraper.mjs --write",
    "setup:packet:export": "node .SYSTEMX/cli/systemx.mjs packet export",
    "setup:packet:import": "node .SYSTEMX/cli/systemx.mjs packet import",
    "setup:test-users": "node scripts/setup/seed-test-users.mjs",
    "setup:test-users:write": "node scripts/setup/seed-test-users.mjs --write",
    "account-levels:check": "node .SYSTEMX/scripts/account-level-check.mjs",
    "auth:mfa:check": "node .SYSTEMX/scripts/auth-mfa-readiness-check.mjs",
    "ci:lint": "eslint . --max-warnings=0",
    "ci:typecheck": "tsc --noEmit -p tsconfig.json",
    "ci:test": "npm test",
    "ci:build": "vite build && node .SYSTEMX/scripts/assert-lan-isolation.mjs",
    "ci:lan-isolation": "node .SYSTEMX/scripts/assert-lan-isolation.mjs",
    "ci:audit": "npm audit --audit-level=high",
    "ci:security": "node .SYSTEMX/scripts/security-check.mjs && node .SYSTEMX/scripts/account-level-check.mjs && node .SYSTEMX/scripts/auth-mfa-readiness-check.mjs",
    "ci:docs": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\" && node .SYSTEMX/scripts/check-markdown-links.mjs",
    "ci:structure": "node .SYSTEMX/scripts/verify-template-structure.mjs",
    "ci:all": "npm run sync:system:check && npm run ci:lint && npm run ci:typecheck && npm run ci:test && npm run ci:security && npm run ci:docs && npm run ci:structure && npm run ci:build"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "lucide-react": "^0.484.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "firebase-tools": "15.24.0",
    "globals": "^17.7.0",
    "markdownlint-cli2": "0.23.1",
    "tailwindcss": "^4.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5"
  }
}
