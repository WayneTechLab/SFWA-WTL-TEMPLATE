# SFWA-WTL-G1 — .SYSTEMX runtime artifacts
# These are generated by WSG-MENU.sh / scripts and should not be committed.

# Deploy logs
logs/
!logs/.gitkeep

# Mutable counters (regenerated each deploy)
version/deploy-count.txt

# Server secrets (never commit)
secrets.env
*.secrets.env
!*.secrets.env.example

# Guided-setup answers (may hold project IDs / Firebase config)
Template/interview.answers
status/setup-state.env
state/local.json

# User/LLM setup outputs. Keep folder anchors only.
Setup-Input_MD/*
!Setup-Input_MD/.gitkeep
!Setup-Input_MD/README.md
