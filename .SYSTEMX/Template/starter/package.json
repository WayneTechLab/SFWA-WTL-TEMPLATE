{
  "name": "sfwa-wtl-g1",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "SFWA-WTL-G1 — Standard Firebase Web App, Wayne Tech Lab Generation 1.",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noCheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "emulators": "npx --no-install firebase emulators:start",
    "emulators:export": "npx --no-install firebase emulators:start --export-on-exit=.emulator-data --import=.emulator-data",
    "setup:test-users": "node scripts/setup/seed-test-users.mjs",
    "setup:test-users:write": "node scripts/setup/seed-test-users.mjs --write",
    "sync:system": "bash .SYSTEMX/wsg-agi.sh",
    "sync:system:check": "bash .SYSTEMX/wsg-agi.sh --check",
    "ci:lint": "eslint . --max-warnings=0",
    "ci:typecheck": "tsc --noEmit -p tsconfig.json",
    "ci:test": "npm run test --if-present",
    "ci:build": "vite build",
    "ci:audit": "npm audit --audit-level=high",
    "ci:security": "bash scripts/security/run_security_checks.sh"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "lucide-react": "^0.484.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "firebase-tools": "15.24.0",
    "globals": "^17.7.0",
    "tailwindcss": "^4.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5"
  }
}
